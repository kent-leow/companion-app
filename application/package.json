{
  "name": "companion",
  "version": "0.1.0",
  "description": "Terminal-based AI agent CLI with skill-based tool system",
  "type": "module",
  "main": "dist/companion.js",
  "bin": {
    "companion": "dist/companion.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --import tsx/esm esbuild.config.ts",
    "start": "node dist/companion.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.1.0",
    "ora": "^8.0.1",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
